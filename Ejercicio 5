import java.util.Scanner;

public class Ejercicio4 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.println("Escriba su Nombre");
        String Nombre = sc.nextLine();
        System.out.println("Digite su Estatura");
        double Estatura = sc.nextDouble();
        System.out.println("Digite su peso en Kg");
        double Peso = sc.nextDouble();

        double IMC = Peso / Math.pow(Estatura,2);


        System.out.println("Señor"+ Nombre);
        System.out.println("Tu IMC es de "+ IMC +"%");
       if(IMC < 18.5 ){
        System.out.println("Peso Bajo es recomendable ir a un medico para aumentar masa muscular");
       }
       if(IMC >= 18.5 && IMC <= 24.9){
        System.out.println("Peso Normal");
       }
       if(IMC >= 25 && IMC <= 29.9){
        System.out.println("Sobrepeso");
       }
       if(IMC >= 30){
        System.out.println("Obesidad, se recomienda bajar de peso");
        
    }
    sc.close();
}
}
